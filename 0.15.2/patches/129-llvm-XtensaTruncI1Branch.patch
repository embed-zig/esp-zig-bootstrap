+static SDValue lowerScalarI1CondToI32(SDValue Cond, SelectionDAG &DAG,
+                                      const SDLoc &DL) {
+  SDValue Mask;
+  if (Cond.getValueType() == MVT::i1 && Cond.getOpcode() == ISD::TRUNCATE &&
+      Cond.getOperand(0).getValueType().isInteger())
+    Mask = DAG.getZExtOrTrunc(Cond.getOperand(0), DL, MVT::i32);
+  else
+    Mask = DAG.getZExtOrTrunc(Cond, DL, MVT::i32);
+
+  return DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                     DAG.getConstant(1, DL, MVT::i32));
+}
+
+static SDValue combineExtendedScalarI1(SDValue Ext, SelectionDAG &DAG) {
+  SDValue Input = Ext.getOperand(0);
+  EVT VT = Ext.getValueType();
+  SDLoc DL(Ext);
+
+  if (Input.getValueType() != MVT::i1 || !VT.isInteger())
+    return SDValue();
+
+  if (Input.getOpcode() == ISD::TRUNCATE &&
+      Input.getOperand(0).getValueType().isInteger()) {
+    SDValue Mask = DAG.getZExtOrTrunc(Input.getOperand(0), DL, VT);
+    return DAG.getNode(ISD::AND, DL, VT, Mask, DAG.getConstant(1, DL, VT));
+  }
+
+  if (Ext.getOpcode() == ISD::ANY_EXTEND)
+    return DAG.getNode(ISD::ZERO_EXTEND, DL, VT, Input);
+
+  return SDValue();
+}
