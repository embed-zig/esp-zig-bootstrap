--- /dev/null
+++ b/llvm/test/CodeGen/Xtensa/xtensa-xtbool-fixup.ll
@@ -0,0 +1,34 @@
+; RUN: llc -O2 -verify-machineinstrs -mtriple=xtensa -mcpu=esp32 %s -o - | FileCheck %s
+
+target datalayout = "e-m:e-p:32:32-v1:8:8-i64:64-i128:128-n32"
+target triple = "xtensa-unknown-unknown-unknown"
+
+define <2 x i1> @fixup_high_group_v2(i1 %cond, <2 x i1> %x, <2 x i1> %y) {
+; CHECK-LABEL: fixup_high_group_v2:
+; CHECK: rsr [[BREG0:a[0-9]+]], br
+; CHECK: l32r [[MASK0:a[0-9]+]], .LCPI0_0
+; CHECK: and [[MASK0]], [[MASK0]], [[BREG0]]
+; CHECK: or [[PACK0:a[0-9]+]], [[MASK0]], {{a[0-9]+}}
+; CHECK: wsr [[PACK0]], br
+; CHECK: rsr [[BREG1:a[0-9]+]], br
+; CHECK: l32r [[MASK1:a[0-9]+]], .LCPI0_1
+; CHECK: and [[MASK1]], [[MASK1]], [[BREG1]]
+; CHECK: slli [[SHIFTED:a[0-9]+]], {{a[0-9]+}}, 2
+; CHECK: or [[PACK1:a[0-9]+]], [[MASK1]], [[SHIFTED]]
+; CHECK: wsr [[PACK1]], br
+; CHECK: extui {{a[0-9]+}}, {{a[0-9]+}}, 2, 2
+entry:
+  br i1 %cond, label %then, label %else
+
+then:
+  %sx = shufflevector <2 x i1> %x, <2 x i1> poison, <2 x i32> <i32 1, i32 0>
+  br label %merge
+
+else:
+  %sy = shufflevector <2 x i1> %y, <2 x i1> poison, <2 x i32> <i32 0, i32 1>
+  br label %merge
+
+merge:
+  %r = phi <2 x i1> [%sx, %then], [%sy, %else]
+  ret <2 x i1> %r
+}
