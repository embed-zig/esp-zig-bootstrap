+static SDValue foldScalarBoolXorOfSetCC(SDValue Val, SelectionDAG &DAG,
+                                        const SDLoc &DL) {
+  if (Val.getOpcode() != ISD::XOR || Val.getValueType() != MVT::i1)
+    return SDValue();
+
+  SDValue LHS = Val.getOperand(0);
+  SDValue RHS = Val.getOperand(1);
+  auto *C = dyn_cast<ConstantSDNode>(RHS);
+  if (!C) {
+    C = dyn_cast<ConstantSDNode>(LHS);
+    std::swap(LHS, RHS);
+  }
+  if (!C || (!C->isOne() && !C->isAllOnes()) ||
+      LHS.getOpcode() != ISD::SETCC)
+    return SDValue();
+
+  SDValue CmpLHS = LHS.getOperand(0);
+  SDValue CmpRHS = LHS.getOperand(1);
+  ISD::CondCode CC = cast<CondCodeSDNode>(LHS.getOperand(2))->get();
+  CC = ISD::getSetCCInverse(CC, CmpLHS.getValueType());
+  return DAG.getSetCC(DL, MVT::i1, CmpLHS, CmpRHS, CC);
+}
