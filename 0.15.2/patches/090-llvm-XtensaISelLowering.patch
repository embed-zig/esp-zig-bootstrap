+void XtensaTargetLowering::ReplaceNodeResults(
+    SDNode *N, SmallVectorImpl<SDValue> &Results, SelectionDAG &DAG) const {
+  if (N->getNumValues() == 0 || N->getValueType(0) != MVT::v3i1)
+    return;
+
+  SDLoc DL(N);
+  switch (N->getOpcode()) {
+  case ISD::LOAD: {
+    auto *Load = cast<LoadSDNode>(N);
+    SDValue Mask =
+        DAG.getExtLoad(ISD::ZEXTLOAD, DL, MVT::i32, Load->getChain(),
+                       Load->getBasePtr(), Load->getPointerInfo(), MVT::i8,
+                       Load->getAlign(), Load->getMemOperand()->getFlags());
+    Mask = clampSmallBoolVectorMask(Mask, MVT::v3i1, DL, DAG);
+    Results.push_back(DAG.getNode(XtensaISD::TRUNC, DL, MVT::v4i1, Mask));
+    Results.push_back(Mask.getValue(1));
+    return;
+  }
+  default: {
+    SDValue Wide = widenSmallBoolVectorResult(SDValue(N, 0), MVT::v4i1, DAG);
+    if (!Wide)
+      return;
+    Results.push_back(Wide);
+    for (unsigned I = 1, E = N->getNumValues(); I != E; ++I)
+      Results.push_back(SDValue(N, I));
+    return;
+  }
+  }
 }
 
