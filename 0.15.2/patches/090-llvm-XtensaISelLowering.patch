+
+static bool isSmallBoolVector(EVT VT) {
+  return VT.isVector() && VT.getVectorElementType() == MVT::i1 &&
+         VT.getSizeInBits() <= 4;
+}
+
+static SDValue getSmallBoolVectorWidthMask(EVT VT, SDLoc DL,
+                                           SelectionDAG &DAG) {
+  return DAG.getConstant((1u << VT.getSizeInBits()) - 1, DL, MVT::i32);
+}
+
+static SDValue clampSmallBoolVectorMask(SDValue Mask, EVT VT, SDLoc DL,
+                                        SelectionDAG &DAG) {
+  return DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                     getSmallBoolVectorWidthMask(VT, DL, DAG));
+}
+
+static SDValue lowerSmallBoolVectorToMask(SDValue Op, SelectionDAG &DAG) {
+  SDLoc DL(Op);
+  EVT VT = Op.getValueType();
+  if (!isSmallBoolVector(VT))
+    return SDValue();
+
+  auto asI32 = [&](SDValue V) {
+    if (V.getValueType() == MVT::i1)
+      if (auto *Load = dyn_cast<LoadSDNode>(V))
+        return DAG.getExtLoad(ISD::ZEXTLOAD, DL, MVT::i32, Load->getChain(),
+                              Load->getBasePtr(), Load->getPointerInfo(),
+                              MVT::i8, Load->getAlign(),
+                              Load->getMemOperand()->getFlags());
+    return DAG.getZExtOrTrunc(V, DL, MVT::i32);
+  };
+  auto extractElt = [&](SDValue Vec, unsigned Idx) {
+    if (Vec.isUndef())
+      return DAG.getConstant(0, DL, MVT::i32);
+    if (SDValue Mask = getSmallBoolVectorValueMask(Vec, DAG)) {
+      if (Idx != 0)
+        Mask = DAG.getNode(ISD::SRL, DL, MVT::i32, Mask,
+                           DAG.getConstant(Idx, DL, MVT::i32));
+      return DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                         DAG.getConstant(1, DL, MVT::i32));
+    }
+    return asI32(DAG.getNode(ISD::EXTRACT_VECTOR_ELT, DL,
+                             VT.getVectorElementType(), Vec,
+                             DAG.getConstant(Idx, DL, MVT::i32)));
+  };
+
+  switch (Op.getOpcode()) {
+  case XtensaISD::TRUNC:
+    return clampSmallBoolVectorMask(Op.getOperand(0), VT, DL, DAG);
+  case ISD::SCALAR_TO_VECTOR:
+    return asI32(Op.getOperand(0));
+  case ISD::BUILD_VECTOR: {
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    for (unsigned I = 0, E = Op->getNumOperands(); I != E; ++I) {
+      SDValue Part = asI32(Op.getOperand(I));
+      if (I != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(I, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+    }
+    return Mask;
+  }
+  case ISD::INSERT_VECTOR_ELT: {
+    auto *IdxNode = dyn_cast<ConstantSDNode>(Op.getOperand(2));
+    if (!IdxNode)
+      return SDValue();
+    unsigned Idx = IdxNode->getZExtValue();
+    if (Idx >= VT.getVectorNumElements())
+      return SDValue();
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    for (unsigned I = 0, E = VT.getVectorNumElements(); I != E; ++I) {
+      SDValue Part =
+          I == Idx ? asI32(Op.getOperand(1)) : extractElt(Op.getOperand(0), I);
+      if (I != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(I, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+    }
+    return Mask;
+  }
+  case ISD::CONCAT_VECTORS: {
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    unsigned Shift = 0;
+    for (unsigned I = 0, E = Op->getNumOperands(); I != E; ++I) {
+      SDValue Part = lowerSmallBoolVectorToMask(Op.getOperand(I), DAG);
+      if (!Part)
+        return SDValue();
+      if (Shift != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(Shift, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+      Shift += Op.getOperand(I).getValueType().getSizeInBits();
+    }
+    return Mask;
+  }
+  case ISD::VECTOR_SHUFFLE: {
+    auto *Shuffle = cast<ShuffleVectorSDNode>(Op);
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    unsigned NumElts = VT.getVectorNumElements();
+    for (unsigned I = 0; I != NumElts; ++I) {
+      int MaskElt = Shuffle->getMaskElt(I);
+      SDValue Part;
+      if (MaskElt < 0) {
+        Part = DAG.getConstant(0, DL, MVT::i32);
+      } else if (static_cast<unsigned>(MaskElt) < NumElts) {
+        Part = extractElt(Op.getOperand(0), MaskElt);
+      } else if (static_cast<unsigned>(MaskElt) < NumElts * 2) {
+        Part = extractElt(Op.getOperand(1), MaskElt - NumElts);
+      } else {
+        return SDValue();
+      }
+      if (I != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(I, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+    }
+    return Mask;
+  }
+  case ISD::AND:
+  case ISD::OR:
+  case ISD::XOR: {
+    SDValue LHS = getSmallBoolVectorValueMask(Op.getOperand(0), DAG);
+    SDValue RHS = getSmallBoolVectorValueMask(Op.getOperand(1), DAG);
+    if (!LHS || !RHS)
+      return SDValue();
+    return DAG.getNode(Op.getOpcode(), DL, MVT::i32, LHS, RHS);
+  }
+  case ISD::SELECT_CC: {
+    SDValue TrueMask = getSmallBoolVectorValueMask(Op.getOperand(2), DAG);
+    SDValue FalseMask = getSmallBoolVectorValueMask(Op.getOperand(3), DAG);
+    if (!TrueMask || !FalseMask)
+      return SDValue();
+    return DAG.getNode(ISD::SELECT_CC, DL, MVT::i32, Op.getOperand(0),
+                       Op.getOperand(1), TrueMask, FalseMask, Op.getOperand(4));
+  }
+  case ISD::SELECT: {
+    SDValue TrueMask = getSmallBoolVectorValueMask(Op.getOperand(1), DAG);
+    SDValue FalseMask = getSmallBoolVectorValueMask(Op.getOperand(2), DAG);
+    if (!TrueMask || !FalseMask)
+      return SDValue();
+    SDValue Cond = DAG.getZExtOrTrunc(Op.getOperand(0), DL, MVT::i32);
+    return DAG.getNode(ISD::SELECT_CC, DL, MVT::i32, Cond,
+                       DAG.getConstant(0, DL, MVT::i32), TrueMask, FalseMask,
+                       DAG.getCondCode(ISD::SETNE));
+  }
+  case ISD::VSELECT: {
+    SDValue Cond = getSmallBoolVectorValueMask(Op.getOperand(0), DAG);
+    SDValue TrueMask = getSmallBoolVectorValueMask(Op.getOperand(1), DAG);
+    SDValue FalseMask = getSmallBoolVectorValueMask(Op.getOperand(2), DAG);
+    if (!Cond || !TrueMask || !FalseMask)
+      return SDValue();
+
+    SDValue WidthMask = getSmallBoolVectorWidthMask(VT, DL, DAG);
+    SDValue InvertedCond =
+        DAG.getNode(ISD::XOR, DL, MVT::i32, Cond, WidthMask);
+    SDValue WhenTrue = DAG.getNode(ISD::AND, DL, MVT::i32, Cond, TrueMask);
+    SDValue WhenFalse =
+        DAG.getNode(ISD::AND, DL, MVT::i32, InvertedCond, FalseMask);
+    return DAG.getNode(ISD::OR, DL, MVT::i32, WhenTrue, WhenFalse);
+  }
+  default:
+    return SDValue();
+  }
+}
+
+static SDValue lowerSmallBoolVectorOp(SDValue Op, SelectionDAG &DAG) {
+  EVT VT = Op.getValueType();
+  if (!isSmallBoolVector(VT))
+    return SDValue();
+
+  SDLoc DL(Op);
+  SDValue Mask = lowerSmallBoolVectorToMask(Op, DAG);
+  if (!Mask)
+    return SDValue();
+
+  Mask = clampSmallBoolVectorMask(Mask, VT, DL, DAG);
+  return DAG.getNode(XtensaISD::TRUNC, DL, VT, Mask);
+}
+
+static SDValue getSmallBoolVectorValueMask(SDValue Vec, SelectionDAG &DAG) {
+  EVT VecVT = Vec.getValueType();
+  if (!isSmallBoolVector(VecVT))
+    return SDValue();
+
+  SDLoc DL(Vec);
+  if (auto *Load = dyn_cast<LoadSDNode>(Vec)) {
+    SDValue Mask =
+        DAG.getExtLoad(ISD::ZEXTLOAD, DL, MVT::i32, Load->getChain(),
+                       Load->getBasePtr(), Load->getPointerInfo(), MVT::i8,
+                       Load->getAlign(), Load->getMemOperand()->getFlags());
+    return clampSmallBoolVectorMask(Mask, VecVT, DL, DAG);
+  }
+
+  return lowerSmallBoolVectorToMask(Vec, DAG);
+}
+
+static SDValue widenSmallBoolVectorResult(SDValue Vec, EVT WidenVT,
+                                          SelectionDAG &DAG) {
+  SDValue Mask = getSmallBoolVectorValueMask(Vec, DAG);
+  if (!Mask)
+    return SDValue();
+
+  SDLoc DL(Vec);
+  return DAG.getNode(XtensaISD::TRUNC, DL, WidenVT, Mask);
+}
+
+static SDValue lowerSmallBoolVectorExtract(SDValue Op, SelectionDAG &DAG) {
+  SDValue Vec = Op.getOperand(0);
+  EVT VecVT = Vec.getValueType();
+  if (!isSmallBoolVector(VecVT))
+    return SDValue();
+
+  auto *IdxNode = dyn_cast<ConstantSDNode>(Op.getOperand(1));
+  if (!IdxNode)
+    return SDValue();
+
+  unsigned Idx = IdxNode->getZExtValue();
+  if (Idx >= VecVT.getVectorNumElements())
+    return SDValue();
+
+  SDLoc DL(Op);
+  SDValue Mask = getSmallBoolVectorValueMask(Vec, DAG);
+  if (!Mask)
+    return SDValue();
+
+  if (Idx != 0)
+    Mask = DAG.getNode(ISD::SRL, DL, MVT::i32, Mask,
+                       DAG.getConstant(Idx, DL, MVT::i32));
+  Mask = DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                     DAG.getConstant(1, DL, MVT::i32));
+  return DAG.getSetCC(DL, Op.getValueType(), Mask,
+                      DAG.getConstant(0, DL, MVT::i32), ISD::SETNE);
+}
+
+static SDValue combineExtendedSmallBoolVectorExtract(SDValue Op,
+                                                     SelectionDAG &DAG) {
+  SDLoc DL(Op);
+  EVT VT = Op.getValueType();
+  SDValue Extract = Op.getOperand(0);
+
+  if (Extract.getValueType() == MVT::i1)
+    if (auto *Load = dyn_cast<LoadSDNode>(Extract))
+      return DAG.getExtLoad(ISD::ZEXTLOAD, DL, VT, Load->getChain(),
+                            Load->getBasePtr(), Load->getPointerInfo(), MVT::i8,
+                            Load->getAlign(), Load->getMemOperand()->getFlags());
+
+  auto getBoolConst = [&](SDValue V, bool &Result) {
+    auto *C = dyn_cast<ConstantSDNode>(V);
+    if (!C)
+      return false;
+    const APInt &Val = C->getAPIntValue();
+    if (Val.isZero()) {
+      Result = false;
+      return true;
+    }
+    if (Val.isOne() || Val.isAllOnes()) {
+      Result = true;
+      return true;
+    }
+    return false;
+  };
+  auto getBitMask = [&](SDValue V) -> SDValue {
+    auto normalizeBitAnd = [&](SDValue AndNode, unsigned ShiftAmt) -> SDValue {
+      if (AndNode.getOpcode() != ISD::AND)
+        return SDValue();
+
+      ConstantSDNode *MaskNode = dyn_cast<ConstantSDNode>(AndNode.getOperand(0));
+      SDValue Value = AndNode.getOperand(1);
+      if (!MaskNode) {
+        MaskNode = dyn_cast<ConstantSDNode>(AndNode.getOperand(1));
+        Value = AndNode.getOperand(0);
+      }
+      if (!MaskNode)
+        return SDValue();
+
+      const APInt &Mask = MaskNode->getAPIntValue();
+      if (ShiftAmt == 0) {
+        if (!Mask.isOne())
+          return SDValue();
+      } else {
+        if (Mask.ugt(APInt::getLowBitsSet(Mask.getBitWidth(), ShiftAmt + 1)))
+          return SDValue();
+        if (!Mask[ShiftAmt])
+          return SDValue();
+      }
+
+      if (ShiftAmt != 0)
+        Value = DAG.getNode(ISD::SRL, DL, VT, Value,
+                            DAG.getConstant(ShiftAmt, DL, VT));
+      return DAG.getNode(ISD::AND, DL, VT, Value, DAG.getConstant(1, DL, VT));
+    };
+
+    if (V.getOpcode() == ISD::AND)
+      return normalizeBitAnd(V, 0);
+
+    if (V.getOpcode() != ISD::SRL)
+      return SDValue();
+
+    auto *ShiftNode = dyn_cast<ConstantSDNode>(V.getOperand(1));
+    if (!ShiftNode)
+      return SDValue();
+
+    return normalizeBitAnd(V.getOperand(0), ShiftNode->getZExtValue());
+  };
+
+  switch (Extract.getOpcode()) {
+  case ISD::SETCC: {
+    ISD::CondCode CC = cast<CondCodeSDNode>(Extract.getOperand(2))->get();
+    if ((CC != ISD::SETNE && CC != ISD::SETEQ) ||
+        !isa<ConstantSDNode>(Extract.getOperand(1)) ||
+        !cast<ConstantSDNode>(Extract.getOperand(1))->isZero())
+      return SDValue();
+    SDValue Mask = getBitMask(Extract.getOperand(0));
+    if (!Mask)
+      return SDValue();
+    if (CC == ISD::SETNE)
+      return Mask;
+    return DAG.getNode(ISD::XOR, DL, VT, Mask, DAG.getConstant(1, DL, VT));
+  }
+  case ISD::SELECT_CC: {
+    bool TrueVal = false;
+    bool FalseVal = false;
+    if (!getBoolConst(Extract.getOperand(2), TrueVal) ||
+        !getBoolConst(Extract.getOperand(3), FalseVal) ||
+        TrueVal == FalseVal)
+      return SDValue();
+    ISD::CondCode CC = cast<CondCodeSDNode>(Extract.getOperand(4))->get();
+    if ((CC != ISD::SETNE && CC != ISD::SETEQ) ||
+        !isa<ConstantSDNode>(Extract.getOperand(1)) ||
+        !cast<ConstantSDNode>(Extract.getOperand(1))->isZero())
+      return SDValue();
+    SDValue Mask = getBitMask(Extract.getOperand(0));
+    if (!Mask)
+      return SDValue();
+    bool OneWhenMaskOne = (CC == ISD::SETNE) ? TrueVal : FalseVal;
+    if (OneWhenMaskOne)
+      return Mask;
+    return DAG.getNode(ISD::XOR, DL, VT, Mask, DAG.getConstant(1, DL, VT));
+  }
+  default:
+    break;
+  }
+
+  if (Extract.getOpcode() != ISD::EXTRACT_VECTOR_ELT)
+    return SDValue();
+
+  SDValue Vec = Extract.getOperand(0);
+  EVT VecVT = Vec.getValueType();
+  if (!isSmallBoolVector(VecVT))
+    return SDValue();
+
+  auto *IdxNode = dyn_cast<ConstantSDNode>(Extract.getOperand(1));
+  if (!IdxNode)
+    return SDValue();
+
+  unsigned Idx = IdxNode->getZExtValue();
+  if (Idx >= VecVT.getVectorNumElements())
+    return SDValue();
+
+  SDValue Mask = getSmallBoolVectorValueMask(Vec, DAG);
+  if (!Mask)
+    return SDValue();
+
+  if (Idx != 0)
+    Mask = DAG.getNode(ISD::SRL, DL, MVT::i32, Mask,
+                       DAG.getConstant(Idx, DL, MVT::i32));
+  Mask = DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                     DAG.getConstant(1, DL, MVT::i32));
+  return DAG.getZExtOrTrunc(Mask, DL, Op.getValueType());
+}
