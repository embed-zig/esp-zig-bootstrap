+static bool isSmallBoolVector(EVT VT) {
+  return VT.isVector() && VT.getVectorElementType() == MVT::i1 &&
+         VT.getSizeInBits() <= 4;
+}
+
+static SDValue lowerSmallBoolVectorToMask(SDValue Op, SelectionDAG &DAG) {
+  SDLoc DL(Op);
+  EVT VT = Op.getValueType();
+  if (!isSmallBoolVector(VT))
+    return SDValue();
+
+  auto asI32 = [&](SDValue V) {
+    return DAG.getZExtOrTrunc(V, DL, MVT::i32);
+  };
+
+  switch (Op.getOpcode()) {
+  case XtensaISD::TRUNC:
+    return Op.getOperand(0);
+  case ISD::SCALAR_TO_VECTOR:
+    return asI32(Op.getOperand(0));
+  case ISD::BUILD_VECTOR: {
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    for (unsigned I = 0, E = Op->getNumOperands(); I != E; ++I) {
+      SDValue Part = asI32(Op.getOperand(I));
+      if (I != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(I, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+    }
+    return Mask;
+  }
+  case ISD::CONCAT_VECTORS: {
+    SDValue Mask = DAG.getConstant(0, DL, MVT::i32);
+    unsigned Shift = 0;
+    for (unsigned I = 0, E = Op->getNumOperands(); I != E; ++I) {
+      SDValue Part = lowerSmallBoolVectorToMask(Op.getOperand(I), DAG);
+      if (!Part)
+        return SDValue();
+      if (Shift != 0)
+        Part = DAG.getNode(ISD::SHL, DL, MVT::i32, Part,
+                           DAG.getConstant(Shift, DL, MVT::i32));
+      Mask = DAG.getNode(ISD::OR, DL, MVT::i32, Mask, Part);
+      Shift += Op.getOperand(I).getValueType().getSizeInBits();
+    }
+    return Mask;
+  }
+  case ISD::OR: {
+    SDValue LHS = lowerSmallBoolVectorToMask(Op.getOperand(0), DAG);
+    SDValue RHS = lowerSmallBoolVectorToMask(Op.getOperand(1), DAG);
+    if (!LHS || !RHS)
+      return SDValue();
+    return DAG.getNode(ISD::OR, DL, MVT::i32, LHS, RHS);
+  }
+  default:
+    return SDValue();
+  }
+}
+
+static SDValue lowerSmallBoolVectorOp(SDValue Op, SelectionDAG &DAG) {
+  EVT VT = Op.getValueType();
+  if (!isSmallBoolVector(VT))
+    return SDValue();
+
+  SDLoc DL(Op);
+  SDValue Mask = lowerSmallBoolVectorToMask(Op, DAG);
+  if (!Mask)
+    return SDValue();
+
+  unsigned WidthMask = (1u << VT.getSizeInBits()) - 1;
+  Mask = DAG.getNode(ISD::AND, DL, MVT::i32, Mask,
+                     DAG.getConstant(WidthMask, DL, MVT::i32));
+  return DAG.getNode(XtensaISD::TRUNC, DL, VT, Mask);
+}
