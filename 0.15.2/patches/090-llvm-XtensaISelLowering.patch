+SDValue XtensaTargetLowering::LowerSELECT(SDValue Op,
+                                          SelectionDAG &DAG) const {
+  SDLoc DL(Op);
+  SDValue Cond = Op.getOperand(0);
+  SDValue TrueValue = Op.getOperand(1);
+  SDValue FalseValue = Op.getOperand(2);
+  EVT VT = TrueValue.getValueType();
+
+  if (!isSmallBoolVector(VT))
+    return SDValue();
+
+  SDValue TrueMask = lowerSmallBoolVectorToMask(TrueValue, DAG);
+  SDValue FalseMask = lowerSmallBoolVectorToMask(FalseValue, DAG);
+  if (!TrueMask || !FalseMask)
+    return SDValue();
+
+  Cond = DAG.getZExtOrTrunc(Cond, DL, MVT::i32);
+  SDValue Zero = DAG.getConstant(0, DL, MVT::i32);
+  SDValue Mask =
+      DAG.getNode(ISD::SELECT_CC, DL, MVT::i32, Cond, Zero, TrueMask,
+                  FalseMask, DAG.getCondCode(ISD::SETNE));
+  return DAG.getNode(XtensaISD::TRUNC, DL, VT, Mask);
+}
