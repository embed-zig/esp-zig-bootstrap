+static SDValue convertLocVTToValVT(SelectionDAG &DAG, SDValue Val,
+                                   const CCValAssign &VA, const SDLoc &DL) {
+  switch (VA.getLocInfo()) {
+  default:
+    llvm_unreachable("Unexpected CCValAssign::LocInfo");
+  case CCValAssign::Full:
+    break;
+  case CCValAssign::BCvt:
+    Val = DAG.getNode(ISD::BITCAST, DL, VA.getValVT(), Val);
+    break;
+  case CCValAssign::SExt:
+    Val = DAG.getNode(ISD::AssertSext, DL, VA.getLocVT(), Val,
+                      DAG.getValueType(VA.getValVT()));
+    Val = DAG.getNode(ISD::TRUNCATE, DL, VA.getValVT(), Val);
+    break;
+  case CCValAssign::ZExt:
+    Val = DAG.getNode(ISD::AssertZext, DL, VA.getLocVT(), Val,
+                      DAG.getValueType(VA.getValVT()));
+    Val = DAG.getNode(ISD::TRUNCATE, DL, VA.getValVT(), Val);
+    break;
+  case CCValAssign::AExt:
+    Val = DAG.getNode(ISD::TRUNCATE, DL, VA.getValVT(), Val);
+    break;
+  }
+  return Val;
+}
+
+static SDValue convertScalarBoolSetCCToI32(SelectionDAG &DAG, SDValue Val,
+                                           const SDLoc &DL) {
+  if (Val.getValueType() != MVT::i1)
+    return SDValue();
+
+  bool Invert = false;
+  if (Val.getOpcode() == ISD::XOR) {
+    SDValue LHS = Val.getOperand(0);
+    SDValue RHS = Val.getOperand(1);
+    auto *C = dyn_cast<ConstantSDNode>(RHS);
+    if (!C) {
+      C = dyn_cast<ConstantSDNode>(LHS);
+      std::swap(LHS, RHS);
+    }
+    if (!C || (!C->isOne() && !C->isAllOnes()))
+      return SDValue();
+    Val = LHS;
+    Invert = true;
+  }
+
+  if (Val.getOpcode() != ISD::SETCC)
+    return SDValue();
+
+  SDValue LHS = Val.getOperand(0);
+  SDValue RHS = Val.getOperand(1);
+  ISD::CondCode CC = cast<CondCodeSDNode>(Val.getOperand(2))->get();
+  if (Invert)
+    CC = ISD::getSetCCInverse(CC, LHS.getValueType());
+
+  EVT CompareVT = LHS.getValueType();
+  if (CompareVT.isInteger() && CompareVT.bitsLT(MVT::i32)) {
+    unsigned ExtendOp =
+        ISD::isSignedIntSetCC(CC) ? ISD::SIGN_EXTEND : ISD::ZERO_EXTEND;
+    LHS = DAG.getNode(ExtendOp, DL, MVT::i32, LHS);
+    RHS = DAG.getNode(ExtendOp, DL, MVT::i32, RHS);
+  }
+
+  return DAG.getNode(ISD::SELECT_CC, DL, MVT::i32, LHS, RHS,
+                     DAG.getConstant(1, DL, MVT::i32),
+                     DAG.getConstant(0, DL, MVT::i32), DAG.getCondCode(CC));
+}
+
+static SDValue convertValVTToLocVT(SelectionDAG &DAG, SDValue Val,
+                                   const CCValAssign &VA, const SDLoc &DL) {
+  if (VA.getValVT() == MVT::i1 && VA.getLocVT() == MVT::i32)
+    if (SDValue Converted = convertScalarBoolSetCCToI32(DAG, Val, DL))
+      return Converted;
+
+  switch (VA.getLocInfo()) {
+  default:
+    llvm_unreachable("Unexpected CCValAssign::LocInfo");
+  case CCValAssign::Full:
+    break;
+  case CCValAssign::BCvt:
+    Val = DAG.getNode(ISD::BITCAST, DL, VA.getLocVT(), Val);
+    break;
+  case CCValAssign::SExt:
+    Val = DAG.getNode(ISD::SIGN_EXTEND, DL, VA.getLocVT(), Val);
+    break;
+  case CCValAssign::ZExt:
+    Val = DAG.getNode(ISD::ZERO_EXTEND, DL, VA.getLocVT(), Val);
+    break;
+  case CCValAssign::AExt:
+    Val = DAG.getNode(VA.getValVT() == MVT::i1 ? ISD::ZERO_EXTEND
+                                                : ISD::ANY_EXTEND,
+                      DL, VA.getLocVT(), Val);
+    break;
+  }
+  return Val;
+}
+
+static SDValue convertScalarBoolAnyExtToZeroExt(SelectionDAG &DAG, SDValue Val,
+                                                const SDLoc &DL) {
+  if (Val.getOpcode() == ISD::ANY_EXTEND &&
+      Val.getOperand(0).getValueType() == MVT::i1 &&
+      Val.getValueType().isInteger())
+    return DAG.getNode(ISD::ZERO_EXTEND, DL, Val.getValueType(),
+                       Val.getOperand(0));
+  return Val;
+}
