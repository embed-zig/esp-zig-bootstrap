+// This defines for L32R and J instruction displacemnt for
+// testing purposes only.
+//
+// L32R carries a signed 16-bit immediate scaled by 4, i.e. a signed 18-bit
+// byte displacement. The largest positive encodable offset is 32767 * 4 =
+// 131068 bytes; 131072 would require a non-encodable +32768 immediate. Keep
+// the placement bound at that exact limit so constant islands do not get
+// placed farther away than the assembler fixup can encode.
+#define MAX_DISP_L32R ((1 << 17) - 4)
 #define BITS_JUMP 18
 
