+static const TargetRegisterClass *
+getStackSlotRegClass(Register Reg, const TargetRegisterClass *RC) {
+  if (Reg.isPhysical()) {
+    if (Xtensa::BRRegClass.contains(Reg))
+      return &Xtensa::BRRegClass;
+    if (Xtensa::BR2RegClass.contains(Reg))
+      return &Xtensa::BR2RegClass;
+    if (Xtensa::BR4RegClass.contains(Reg))
+      return &Xtensa::BR4RegClass;
+  }
+
+  return RC;
 }
 
