 using namespace llvm;
 
+static bool getBoolStackOpcodeInfo(unsigned Opcode, unsigned &BRegBase,
+                                   unsigned &Arity) {
+  switch (Opcode) {
+  case Xtensa::SPILL_BOOL:
+  case Xtensa::RESTORE_BOOL:
+    BRegBase = Xtensa::B0;
+    Arity = 1;
+    return true;
+  case Xtensa::SPILL_BOOL2:
+  case Xtensa::RESTORE_BOOL2:
+    BRegBase = Xtensa::B0_B1;
+    Arity = 2;
+    return true;
+  case Xtensa::SPILL_BOOL4:
+  case Xtensa::RESTORE_BOOL4:
+    BRegBase = Xtensa::B0_B1_B2_B3;
+    Arity = 4;
+    return true;
+  default:
+    return false;
+  }
+}
+
